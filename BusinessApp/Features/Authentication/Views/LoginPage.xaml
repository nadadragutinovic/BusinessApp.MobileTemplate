<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    x:Class="BusinessApp.Features.Authentication.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Login">

    <Grid
        BackgroundColor="{StaticResource BackgroundColor}"
        Padding="30">

        <VerticalStackLayout
            VerticalOptions="Center"
            Spacing="20">

            <Label
                Text="BusinessApp"
                FontSize="32"
                FontAttributes="Bold"
                HorizontalOptions="Center"/>

            <Label
                Text="Welcome back"
                HorizontalOptions="Center"/>

            <Button
                Text="Sign In"/>

        </VerticalStackLayout>

    </Grid>

</ContentPage>