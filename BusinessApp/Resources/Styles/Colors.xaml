<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Note: For Android please see also Platforms\Android\Resources\values\colors.xml -->

    <!-- Brand -->
    <Color x:Key="PrimaryColor">#2563EB</Color>
    <Color x:Key="PrimaryDarkColor">#1D4ED8</Color>

    <!-- Semantic -->
    <Color x:Key="SuccessColor">#22C55E</Color>
    <Color x:Key="WarningColor">#F59E0B</Color>
    <Color x:Key="ErrorColor">#DC2626</Color>

    <!-- Neutral -->
    <Color x:Key="BackgroundColor">#F8FAFC</Color>
    <Color x:Key="SurfaceColor">White</Color>

    <Color x:Key="BorderColor">#E5E7EB</Color>

    <Color x:Key="PrimaryTextColor">#111827</Color>
    <Color x:Key="SecondaryTextColor">#6B7280</Color>
</ResourceDictionary>